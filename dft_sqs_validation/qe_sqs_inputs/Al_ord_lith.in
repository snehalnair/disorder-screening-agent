&CONTROL
  calculation = 'scf'
  prefix = 'Al_ord_lith'
  outdir = './tmp_Al_ord_lith'
  pseudo_dir = './pseudo'
  tprnfor = .false.
  tstress = .false.
  verbosity = 'low'
  disk_io = 'low'
/

&SYSTEM
  ibrav = 0
  nat = 72
  ntyp = 4
  ecutwfc = 40.0
  ecutrho = 320.0
  occupations = 'smearing'
  smearing = 'mv'
  degauss = 0.02
  nspin = 2
  starting_magnetization(2) = 0.5
  lda_plus_u = .true.
  Hubbard_U(2) = 3.32
/

&ELECTRONS
  conv_thr = 1e-05
  mixing_mode = 'local-TF'
  mixing_beta = 0.1
  electron_maxstep = 500
  diagonalization = 'david'
/

