&CONTROL
  calculation = 'scf'
  prefix = 'Al_sqs1_delith'
  outdir = './tmp_Al_sqs1_delith'
  pseudo_dir = './pseudo'
  tprnfor = .false.
  tstress = .false.
  verbosity = 'low'
  disk_io = 'low'
/

&SYSTEM
  ibrav = 0
  nat = 54
  ntyp = 3
  ecutwfc = 40.0
  ecutrho = 320.0
  occupations = 'smearing'
  smearing = 'mv'
  degauss = 0.02
  nspin = 2
  starting_magnetization(2) = 0.5
  lda_plus_u = .true.
  Hubbard_U(2) = 3.32
/

&ELECTRONS
  conv_thr = 1e-05
  mixing_mode = 'local-TF'
  mixing_beta = 0.1
  electron_maxstep = 500
  diagonalization = 'david'
/

