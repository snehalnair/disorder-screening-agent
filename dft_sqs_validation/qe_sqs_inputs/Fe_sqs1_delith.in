&CONTROL
  calculation = 'scf'
  prefix = 'Fe_sqs1_delith'
  outdir = './tmp_Fe_sqs1_delith'
  pseudo_dir = './pseudo'
  tprnfor = .false.
  tstress = .false.
  verbosity = 'low'
  disk_io = 'low'
/

&SYSTEM
  ibrav = 0
  nat = 54
  ntyp = 3
  ecutwfc = 40.0
  ecutrho = 320.0
  occupations = 'smearing'
