  calculation = 'scf'
  prefix = 'Ti_sqs1_lith'
  outdir = './tmp_Ti_sqs1_lith'
  pseudo_dir = './pseudo'
  tprnfor = .false.
  tstress = .false.
  verbosity = 'low'
  disk_io = 'low'
/

&SYSTEM
  ibrav = 0
  nat = 72
  ntyp = 4
  ecutwfc = 40.0
  ecutrho = 320.0
